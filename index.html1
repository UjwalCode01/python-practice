<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ujwal Daivikar | Mega Portfolio</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- HERO SECTION (Aapka Royal Dark Intro) -->
    <header class="hero">
        <h1>Ujwal Daivikar</h1>
        <p class="subtitle">Full-Stack Developer | AI Engineer | Cloud & CAD Specialist</p>
        
        <!-- 🎯 FILTER BUTTONS: Isse user jis domain par click karega, sirf wahi projects dikhenge! -->
        <div class="filter-tabs">
            <button class="tab-btn active" data-filter="all">All Projects</button>
            <button class="tab-btn" data-filter="Python">Python</button>
            <button class="tab-btn" data-filter="Java">Java</button>
            <button class="tab-btn" data-filter="DSA">DSA</button>
            <button class="tab-btn" data-filter="AI">AI</button>
            <button class="tab-btn" data-filter="Cloud">Cloud</button>
            <button class="tab-btn" data-filter="AutoCAD">AutoCAD / CAD</button>
        </div>
    </header>

    <!-- PROJECTS GRID (Yahan saare 30 projects bina khichdi bane automatic filter hokar aayenge) -->
    <section class="projects-container">
        <div id="projects-grid" class="grid">
            <!-- JavaScript data se yahan automatic sahi category me card daal dega -->
        </div>
    </section>

    <!-- JavaScript connection -->
    <script src="script.js"></script>
</body>
</html>